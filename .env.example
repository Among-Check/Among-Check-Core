# Among-Check Core — optional runtime configuration
# Copy to .env for local development (never commit .env)

# Global scan defaults
AMONG_CHECK_TIMEOUT_MS=30000
AMONG_CHECK_PARALLEL=16

# MCP server (when HTTP transport is enabled)
# AMONG_CHECK_MCP_PORT=3100

# Test actors for tenant-isolation scans (path to JSON file)
# AMONG_CHECK_AUTH_ACTORS=./actors.example.json

# External APIs (optional)
# OSV_API_URL=https://api.osv.dev/v1
